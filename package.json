{
  "name": "shiki-image",
  "version": "0.1.4",
  "description": "Convert code snippets into images. Powered by shiki and takumi. Super fast.",
  "repository": "pi0/shiki-image",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./core": "./dist/core.mjs"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "dev": "vitest dev",
    "lint": "eslint . && prettier -c .",
    "lint:fix": "automd && eslint . --fix && prettier -w .",
    "bench": "node --expose-gc benchs/index.ts",
    "prepack": "pnpm build",
    "release": "pnpm test && changelogen --release && npm publish && git push --follow-tags",
    "test": "pnpm lint && pnpm test:types && vitest run --coverage",
    "test:types": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "shiki": "^4.0.2",
    "takumi-js": "^1.0.14"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "csstype": "^3.2.3",
    "eslint": "^10.2.1",
    "eslint-config-unjs": "^0.6.2",
    "mitata": "^1.0.34",
    "obuild": "^0.4.33",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0"
}
